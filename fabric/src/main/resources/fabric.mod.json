{
	"schemaVersion": 1,
	"id": "halfbright",
	"version": "${version}",
	"name": "Halfbright",
	"description": "Halfbright allows Minecraft to be brighter without looking worse",
	"authors": [
		"L3-N0X"
	],
	"contact": {
		"sources": "https://github.com/L3-N0X/halfbright"
	},
	"license": "MIT",
	"icon": "assets/halfbright/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "de.lenox.fabric.HalfbrightFabric",
				"adapter": "kotlin"
			}
		],
		"sodium:config_api_user": [
			"de.lenox.fabric.HalfbrightSodiumConfig"
		]
	},
	"mixins": [
		"halfbright.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.16.0",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}
